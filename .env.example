# Environment Configuration Example
# Copy this file to .env and fill with your actual values

# Node Environment
NODE_ENV=development
PORT=3001

# Database
MONGODB_URI=mongodb://localhost:27017/fredy-ai
MONGODB_USER=admin
MONGODB_PASSWORD=password

# Firebase (optional)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain

# AI API Keys - Get these for FREE from:
# OpenAI: https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/
# Google Gemini: https://makersuite.google.com/app/apikey
# Groq: https://console.groq.com/

OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_GEMINI_KEY=your-google-gemini-key-here
GROQ_API_KEY=your-groq-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-key-here

# Google Cloud Vision API
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLOUD_VISION_KEY=your-google-vision-key-here
GOOGLE_PROJECT_ID=your-google-project-id

# 9router Configuration
NINE_ROUTER_URL=http://localhost:8000
NINE_ROUTER_API_KEY=optional-if-auth-enabled
NINE_ROUTER_ENABLED=true

# FreeLLMAPI Configuration
FREE_LLM_API_URL=http://localhost:3002
FREE_LLM_API_KEY=optional-api-key
FREE_LLM_ENABLED=true

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_ENABLED=true

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# File Upload
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf
UPLOAD_DIRECTORY=./uploads

# CORS Configuration
CORS_ORIGIN=http://localhost:19000,http://localhost:3000

# Email Configuration (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@fredyai.com

# AWS S3 (optional for file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=fredy-unlimited-ai

# Redis (optional for caching)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Mobile App Config
REACT_NATIVE_API_URL=http://localhost:3001
REACT_NATIVE_LOG_LEVEL=debug
